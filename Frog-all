#include <bits/stdc++.h>
using namespace std;
int ans(int n,vector<int>&arr,vector<int>&dp){
    if(n<=0)
    return 0;
    if(dp[n]!=-1)
    return dp[n];
    int one=abs(arr[n]-arr[n-1])+ans(n-1,arr,dp);
    int two=abs(arr[n]-arr[n-2])+ans(n-2,arr,dp);
    return dp[n]= min(one,two);
}
int main() {
	// your code goes here
	int n=4;
    vector<int>arr={10,20,30,10};
    vector<int>dp(n,-1);
    dp[0]=0;
    dp[1]=arr[1]-arr[0];
    for(int i=2;i<n;i++){
        dp[i]=min(dp[i-1]+abs(arr[i]-arr[i-1]),dp[i-2]+abs(arr[i]-arr[i-2]));
    }
    int prev1=arr[1]-arr[0];
    int prev2=0;
    for(int i=2;i<n;i++){
        int state=min(prev1+abs(arr[i]-arr[i-1]),prev2+abs(arr[i]-arr[i-2]));
        prev2=prev1;
        prev1=state;
        
    }
    cout<<prev1<<endl;
    cout<<dp[n-1]<<endl;
    cout<<ans(n-1,arr,dp);
}
