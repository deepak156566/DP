#include <bits/stdc++.h>
using namespace std;
int ans(int n,vector<int>&arr,vector<int>&dp){
    if(n<0)
    return 0;
    if(n==0)
    return arr[0];
    int take=arr[n]+ans(n-2,arr,dp);
    int ntake=ans(n-1,arr,dp);
    return max(take,ntake);

}
